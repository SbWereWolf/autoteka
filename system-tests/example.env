# INFRA_ROOT — абсолютный путь к каталогу infrastructure.
# Win: C:\WORK\kv1.me\autoteka\20260302-mock\autoteka-mock-app\infrastructure
# WSL: /mnt/c/WORK/kv1.me/autoteka/app-draft/infrastructure
INFRA_ROOT=

# BASH_PATH — путь к bash для тестов backup/restore (TC-DEPLOY-024).
# Win: C:\Program Files\Git\bin\bash.exe
# Nix: /usr/bin/bash
BASH_PATH=

# Профиль run-vitest, если не передан аргумент --profile (см. npm scripts в package.json).
AUTOTEKA_SYSTEM_TESTS_PROFILE=quick-local

# Имя runtime instance, если не задано в infrastructure/*.test.env (профили со stack=local).
RUN_INSTANCE=autoteka

# Базовый URL для профилей со stack=local, если не заданы --base-url и BASE_URL.
SYSTEM_TESTS_LOCAL_BASE_URL=http://127.0.0.1:8081

# Порт хостового Vite (npm run dev) для ui-headless-dev при FRONTEND_MODE=source.
AUTOTEKA_DEV_FRONTEND_PORT=4174

# Хост для аргумента --host у Vite и для HTTP-ожиданий dev-сервера на хосте.
SYSTEM_TESTS_VITE_DEV_BIND_HOST=127.0.0.1
SYSTEM_TESTS_VITE_DEV_URL_HOST=127.0.0.1

# Upstream для compose при проксировании на хостовый Vite.
SYSTEM_TESTS_FRONTEND_UPSTREAM_HOST=host.docker.internal

# Таймауты preflight: docker health и HTTP-проверки (секунды).
SYSTEM_TESTS_DOCKER_STARTUP_TIMEOUT_SEC=120
SYSTEM_TESTS_DOCKER_POLL_INTERVAL_SEC=2

# curl --max-time (секунды) в цикле ожидания HTTP.
SYSTEM_TESTS_CURL_MAX_TIME_SEC=5

# Ожидание подъёма host frontend dev server (секунды).
SYSTEM_TESTS_HOST_FRONTEND_READY_TIMEOUT_SEC=120
SYSTEM_TESTS_HOST_FRONTEND_POLL_INTERVAL_SEC=2

# Teardown: не останавливать compose при выходе из run-vitest (1 — пропустить docker compose down).
# SYSTEM_TESTS_SKIP_COMPOSE_DOWN=1
