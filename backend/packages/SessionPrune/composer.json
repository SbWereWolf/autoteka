{
  "name": "autoteka/laravel-session-prune",
  "description": "Laravel package с командой очистки истёкших сессий.",
  "version": "1.0.0",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Autoteka\\SessionPrune\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Autoteka\\SessionPrune\\SessionPruneServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
