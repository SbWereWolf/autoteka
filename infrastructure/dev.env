# Шаблон docker dev (docker-compose.dev.yml).
# Перед install: cp -n "$INFRA_ROOT/dev.env" "$INFRA_ROOT/.env"

# --- 1. Пути, корни, instance ---
AUTOTEKA_OPTIONS_FILE=/etc/autoteka/options.env
AUTOTEKA_ROOT=/mnt/c/WORK/kv1.me/autoteka/
INFRA_ROOT=/mnt/c/WORK/kv1.me/autoteka/infrastructure/
AUTOTEKA_RUNTIME_INSTANCE=autoteka

# --- 2. Сеть ---
# Только prod web
# HTTP_BIND_HOST=0.0.0.0
# HTTP_PORT=80

# Только docker dev (см. dev.env)
DEV_BIND_HOST=127.0.0.1
DEV_WEB_PORT=8081

# --- 3. Smoke и таймауты ---
PHP_READY_TIMEOUT=60
# ADMIN_SMOKE_URL=http://127.0.0.1:8081/admin/login
# BACKEND_SMOKE_URL=http://127.0.0.1:8081/up
# API_SMOKE_URL=http://127.0.0.1:8081/api/v1/category-list
# HTTP_SMOKE_RETRIES=20
# HTTP_SMOKE_DELAY_SEC=2

# --- 4. Сборка образов ---
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# --- 5. Laravel в контейнере php ---
# RUN_LARAVEL_OPTIMIZE=true

RUN_MIGRATIONS=true

# --- 6. PHP-FPM и OpCache ---
# PHP_FPM_PM_MAX_CHILDREN=20
# PHP_FPM_PM_START_SERVERS=4
# PHP_FPM_PM_MIN_SPARE_SERVERS=2
# PHP_FPM_PM_MAX_SPARE_SERVERS=6
# PHP_OPCACHE_VALIDATE_TIMESTAMPS=0
# PHP_OPCACHE_REVALIDATE_FREQ=0

# --- 7. Healthcheck сервиса php в Compose ---
PHP_HC_INTERVAL=30s
PHP_HC_TIMEOUT=5s
PHP_HC_RETRIES=3
PHP_HC_START_PERIOD=450s

# --- 8. Сервис web: сборка фронта и кэш API ---
VITE_API_BASE_URL=/api/v1
VITE_BUILD_SOURCEMAP=true
FRONTEND_BUILD_SOURCEMAP=true

API_CACHE_TTL=0
API_CACHE_CONTROL_GET="public, max-age=0"
API_CACHE_CONTROL_MUTATION=no-store,no-cache,must-revalidate,max-age=0

# --- 9. upstream к Vite, CORS, кэш в compose, xdebug ---
FRONTEND_MODE=source
FRONTEND_PORT=5173
FRONTEND_UPSTREAM_HOST=frontend
FRONTEND_UPSTREAM_PORT=
FRONTEND_HMR_PROTOCOL=ws
FRONTEND_HMR_HOST=localhost
FRONTEND_HMR_PORT=8081

CORS_ALLOW_ORIGIN=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With
CORS_EXPOSE_HEADERS=Content-Length,Content-Range
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=86400

# --- 11. Xdebug (dev php) ---
BACKEND_XDEBUG_MODE=debug,develop
BACKEND_XDEBUG_START_WITH_REQUEST=yes
BACKEND_XDEBUG_CLIENT_HOST=host.docker.internal
BACKEND_XDEBUG_CLIENT_PORT=9003
BACKEND_XDEBUG_IDEKEY=VSCODE

# --- 12. Git: watch-changes (хост) ---
# BRANCH=master
# REMOTE=origin

# --- 13. Watchdog и health URL (хост) ---
# WATCHDOG_LOAD_LIMIT=2.0
# WATCHDOG_RAM_LIMIT=90
# WATCHDOG_BOOT_GRACE=180
# WATCHDOG_STAGE1_MAX_FAILS=2
# WATCHDOG_STAGE2_MAX_FAILS=4
# WATCHDOG_REBOOT_COOLDOWN=3600
# WATCHDOG_NGINX_FAIL_THRESHOLD=2
# WATCHDOG_PHP_FAIL_THRESHOLD=2
# WATCHDOG_BACKEND_FAIL_THRESHOLD=2
# WATCHDOG_ADMIN_FAIL_THRESHOLD=2
# WATCHDOG_API_FAIL_THRESHOLD=2
# WATCHDOG_NGINX_REPAIR_COOLDOWN=600
# WATCHDOG_PHP_REPAIR_COOLDOWN=600
# WATCHDOG_BACKEND_REPAIR_COOLDOWN=1800
# WATCHDOG_ADMIN_REPAIR_COOLDOWN=1800
# WATCHDOG_API_REPAIR_COOLDOWN=0
# WATCHDOG_NGINX_MAX_REPAIRS=2
# WATCHDOG_PHP_MAX_REPAIRS=2
# WATCHDOG_BACKEND_MAX_REPAIRS=2
# WATCHDOG_ADMIN_MAX_REPAIRS=2
# WATCHDOG_API_MAX_REPAIRS=0
# WATCHDOG_NGINX_REPAIR_VERIFY_TIMEOUT=75
# WATCHDOG_PHP_REPAIR_VERIFY_TIMEOUT=75
# WATCHDOG_CONTAINER_REPAIR_VERIFY_INTERVAL=3

# BACKEND_UP_URL=http://127.0.0.1:8081/up
# API_HEALTH_URL=http://127.0.0.1:8081/api/v1/category-list
# ADMIN_HEALTH_URL=http://127.0.0.1:8081/admin/login

# --- 14. Резервное копирование (хост) ---
# STORAGE_BACKUP_RETENTION_DAYS=7

# --- 15. Логи, health state, temp ---
AUTOTEKA_LOG_DIR=/var/log/autoteka
HEALTH_STATE_DIR=/var/lib/autoteka/health
TMPDIR=/tmp

# --- 16. Telegram (секреты после install уходят в TELEGRAM_ENV_FILE) ---
TELEGRAM_ENV_FILE=/etc/autoteka/telegram.env
TELEGRAM_TOKEN=
TELEGRAM_CHAT=

# MOONSHINE_ADMIN_EMAIL=admin@example.com
