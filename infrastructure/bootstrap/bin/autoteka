#!/usr/bin/env bash
set -euo pipefail

if [ -z "${AUTOTEKA_OPTIONS_FILE:-}" ]; then
  echo "AUTOTEKA_OPTIONS_FILE не задан. Задайте вручную: export AUTOTEKA_OPTIONS_FILE=/path или source options.env. См. ADMIN_MANUAL." >&2
  exit 3
fi
ENV_FILE="$AUTOTEKA_OPTIONS_FILE"

load_env_if_present() {
  if [ -f "$ENV_FILE" ]; then
        set -a
    source "$ENV_FILE" || true
    set +a
  fi
}

ensure_autoteka_root() {
  load_env_if_present
  if [ -z "${AUTOTEKA_ROOT:-}" ]; then
    echo "AUTOTEKA_ROOT is not set. Set it in $ENV_FILE or export AUTOTEKA_ROOT." >&2
    exit 1
  fi
}

ensure_infra_root() {
  if [ -n "${INFRA_ROOT:-}" ] && [ -d "$INFRA_ROOT" ]; then
    return 0
  fi

  echo "INFRA_ROOT не задан или не указывает на каталог infra." >&2
  echo "Задайте абсолютный путь." >&2
  echo "Пример: export INFRA_ROOT=/opt/vue-app/infrastructure" >&2
  exit 2
}

validate_required_paths() {
  local missing=""
  if [ -z "${AUTOTEKA_ROOT:-}" ]; then
    missing="AUTOTEKA_ROOT"
  elif [[ "${AUTOTEKA_ROOT}" != /* ]]; then
    missing="AUTOTEKA_ROOT (относительный путь не допускается)"
  fi
  if [ -z "${INFRA_ROOT:-}" ]; then
    [ -n "$missing" ] && missing="$missing, "
    missing="${missing}INFRA_ROOT"
  elif [[ "${INFRA_ROOT}" != /* ]]; then
    [ -n "$missing" ] && missing="$missing, "
    missing="${missing}INFRA_ROOT (относительный путь не допускается)"
  fi
  if [ -n "$missing" ]; then
    echo "$missing не задан или задан относительным путём." >&2
    echo "Задайте абсолютные пути одним из способов:" >&2
    echo "" >&2
    echo "Через переменные окружения:" >&2
    echo "  export AUTOTEKA_ROOT=/opt/vue-app" >&2
    echo "  export INFRA_ROOT=/opt/vue-app/infrastructure" >&2
    echo "  autoteka deploy" >&2
    echo "" >&2
    echo "Через аргументы (если поддерживаются):" >&2
    echo "  autoteka deploy --autoteka-root=/opt/vue-app --infra-root=/opt/vue-app/infrastructure" >&2
    exit 2
  fi
}

print_global_usage() {
  cat <<'USAGE'
Usage:
  autoteka <command> [arguments] [options]
  autoteka help [command]
  autoteka --help

Purpose:
  Unified entrypoint for runtime control, monitoring, repair, backup, restore and
  uninstall operations for autoteka.

Commands:
  up                Bring up the Docker Compose stack.
  down              Stop the Docker Compose stack.
  deploy            Roll out the current git HEAD in the existing working copy.
  watch-changes     Poll git remote and deploy when new commits appear.
  watchdog          Run health checks and bounded auto-remediation.
  repair-runtime    Heavy Laravel runtime repair with smoke checks.
  repair-health     Targeted auto-repair for one health domain.
  health-reset      Clear incident state and Telegram dedup locks.
  repair-infra      Re-enable timers and reset watchdog counters.
  diagnose          Show overall status and suggest repair commands.
  timers-stop       Stop all autoteka timers.
  timers-start      Start all autoteka timers.
  maintenance       Run periodic maintenance tasks.
  backup            Create a configuration and data backup archive.
  backup-storage    Create storage+database backup archive.
  restore           Restore configuration and data from a backup archive.
  uninstall         Remove installed services/configuration by mode.

Get command-specific help:
  autoteka <command> --help
  autoteka help <command>
USAGE
}

print_up_usage() {
  cat <<'USAGE'
Usage:
  autoteka up

Purpose:
  Start or recreate the deployment Docker Compose stack: базовый файл
  INFRA_ROOT/runtime/docker-compose.yml; при DEPLOY_ENV=prod дополнительно
  подключается INFRA_ROOT/runtime/docker-compose.prod.yml (см. options.env).

Arguments:
  none

Accepted values:
  none
USAGE
}

print_down_usage() {
  cat <<'USAGE'
Usage:
  autoteka down

Purpose:
  Stop the deployment Docker Compose stack (тот же набор compose-файлов,
  что и у autoteka up: базовый yml и при DEPLOY_ENV=prod — prod-оверлей).

Arguments:
  none

Accepted values:
  none
USAGE
}

print_deploy_usage() {
  cat <<'USAGE'
Usage:
  autoteka deploy

Purpose:
  Roll out the current local git HEAD from AUTOTEKA_ROOT without fetching or
  resetting the repository. Intended for manual re-run of deployment steps for
  the current working copy.

Arguments:
  none

Accepted values:
  none
USAGE
}

print_watch_changes_usage() {
  cat <<'USAGE'
Usage:
  autoteka watch-changes

Purpose:
  Fetch REMOTE/BRANCH, compare it with the current HEAD, and if new commits are
  detected then stash local changes, reset the worktree, and run autoteka deploy.

Arguments:
  none

Accepted values:
  none

Important environment values used by the script:
  BRANCH   Git branch to watch. Default: master
  REMOTE   Git remote to watch. Default: origin
USAGE
}

print_watchdog_usage() {
  cat <<'USAGE'
Usage:
  autoteka watchdog [--dry-run]

Purpose:
  Run docker liveness checks for nginx/php, run software checks for /up,
  /api/v1/category-list and /admin/login, then apply bounded auto-remediation
  with thresholds, cooldowns and Telegram dedup locks.

Arguments:
  --dry-run, -n   Print actions and decisions without changing state, restarting
                  containers or sending Telegram messages.
  --help, -h      Show this help.

Accepted values:
  --dry-run       Boolean flag. No value.
  --help          Boolean flag. No value.
USAGE
}

print_repair_runtime_usage() {
  cat <<'USAGE'
Usage:
  autoteka repair-runtime [--dry-run] [--preserve-health-state]

Purpose:
  Heavy Laravel runtime repair: start/rebuild php, prepare writable paths,
  clear optimization caches, verify sqlite/session/cache writes, start/rebuild
  web, then run smoke checks for /up, /api/v1/category-list and /admin/login.

Arguments:
  --dry-run, -n              Print the commands without executing them.
  --preserve-health-state    Do not reset watchdog health incident state after a
                             successful repair.
  --help, -h                 Show this help.

Accepted values:
  --dry-run                  Boolean flag. No value.
  --preserve-health-state    Boolean flag. No value.
  --help                     Boolean flag. No value.
USAGE
}

print_repair_health_usage() {
  cat <<'USAGE'
Usage:
  autoteka repair-health <domain> [--dry-run]

Purpose:
  Run targeted remediation for a single health domain.

Arguments:
  <domain>           Health domain to repair.
                     Allowed values: nginx | php | backend | admin
  --dry-run, -n      Print the commands without executing them.
  --help, -h         Show this help.

Accepted values:
  <domain>=nginx     Restart or recreate the web container.
  <domain>=php       Restart or recreate the php-fpm container.
  <domain>=backend   Run Laravel runtime repair for backend failures.
  <domain>=admin     Run Laravel runtime repair for admin-area failures.
USAGE
}

print_health_reset_usage() {
  cat <<'USAGE'
Usage:
  autoteka health-reset <target> [--dry-run]

Purpose:
  Clear active watchdog incident state and Telegram dedup locks for one health
  domain or for all health domains.

Arguments:
  <target>           Incident target to reset.
                     Allowed values: nginx | php | backend | admin | api | all
  --dry-run, -n      Print what would be removed without changing anything.
  --help, -h         Show this help.

Accepted values:
  <target>=nginx     Reset only nginx health incident state.
  <target>=php       Reset only php health incident state.
  <target>=backend   Reset only backend (/up) incident state.
  <target>=admin     Reset only admin (/admin/login) incident state.
  <target>=api       Reset only API incident state.
  <target>=all       Reset every health domain.
USAGE
}

print_diagnose_usage() {
  cat <<'USAGE'
Usage:
  autoteka diagnose

Purpose:
  Show overall status (containers, timers, health endpoints, recent logs)
  and suggest repair commands. Read-only, does not change state.

Arguments:
  none

Accepted values:
  none
USAGE
}

print_repair_infra_usage() {
  cat <<'USAGE'
Usage:
  autoteka repair-infra

Purpose:
  Re-enable core timers, reset watchdog counters and verify docker.service after
  reboot or after infrastructure-level drift.

Arguments:
  none

Accepted values:
  none
USAGE
}

print_timers_stop_usage() {
  cat <<'USAGE'
Usage:
  autoteka timers-stop

Purpose:
  Stop all autoteka timers (watch-changes, server-watchdog, server-maintenance).

Arguments:
  none
USAGE
}

print_timers_start_usage() {
  cat <<'USAGE'
Usage:
  autoteka timers-start

Purpose:
  Start all autoteka timers. Uses systemctl enable --now and restart.

Arguments:
  none
USAGE
}

print_maintenance_usage() {
  cat <<'USAGE'
Usage:
  autoteka maintenance

Purpose:
  Run periodic maintenance tasks defined by INFRA_ROOT/maintenance/server-maintenance.sh.

Arguments:
  none

Accepted values:
  none
USAGE
}

print_backup_usage() {
  cat <<'USAGE'
Usage:
  autoteka backup [--output-dir=PATH]

Purpose:
  Create a backup archive with deploy configuration, secrets, project .env files,
  installed units and system configs managed by this project.

Arguments:
  --output-dir=PATH   Directory where the backup archive will be created.
                      Default: /root
  --help, -h          Show this help.

Accepted values:
  PATH                Any writable directory path.
USAGE
}

print_restore_usage() {
  cat <<'USAGE'
Usage:
  autoteka restore <archive> [--dry-run] [--force] [--target-root=PATH]

Purpose:
  Restore deploy configuration from a backup archive, then clear runtime health
  incident state so monitoring starts from a clean baseline.

Arguments:
  <archive>            Backup archive created by autoteka backup.
  --dry-run            Print planned actions without writing files or state.
  --force              Skip interactive confirmation.
  --target-root=PATH   Restore backend/.env and frontend/.env into PATH and set
                       AUTOTEKA_ROOT in options.env to PATH.
  --help, -h           Show this help.

Accepted values:
  <archive>            Path to autoteka-backup-*.tar.gz
  --dry-run            Boolean flag. No value.
  --force              Boolean flag. No value.
  PATH                 Any target project root path.
USAGE
}

print_backup_storage_usage() {
  cat <<'USAGE'
Usage:
  autoteka backup-storage [--dry-run]

Purpose:
  Create an archive with backend storage and SQLite database, then rotate
  old archives according to retention policy from /etc/autoteka/options.env.

Arguments:
  --dry-run, -n      Print planned actions without creating archive.
  --help, -h         Show this help.

Accepted values:
  --dry-run          Boolean flag. No value.
USAGE
}

print_uninstall_usage() {
  cat <<'USAGE'
Usage:
  autoteka uninstall <mode> [--force] [--rm-etc] [--rm-storage-backups] [--rm-root]

Purpose:
  Remove installed autoteka services/configuration with a chosen destruction
  level.

Arguments:
  <mode>            Removal mode.
                    Allowed values: soft | purge | nuke
  --force           Skip interactive confirmation.
  --rm-etc          Also remove /etc/autoteka/* secrets.
                    Meaningful for purge and nuke.
  --rm-storage-backups
                    Also remove directory from STORAGE_BACKUP_DIR.
                    Meaningful for purge and nuke.
  --rm-root         Also remove AUTOTEKA_ROOT recursively.
                    Meaningful for nuke.
  --help, -h        Show this help.

Accepted values:
  <mode>=soft       Stop/disable timers and services, compose down, no file removal.
  <mode>=purge      soft + remove app units, logrotate rules, app logs and state.
  <mode>=nuke       purge + remove system configs installed by install.sh.
USAGE
}

print_command_usage() {
  case "$1" in
    up) print_up_usage ;;
    down) print_down_usage ;;
    deploy) print_deploy_usage ;;
    watch-changes) print_watch_changes_usage ;;
    watchdog) print_watchdog_usage ;;
    repair-runtime) print_repair_runtime_usage ;;
    repair-health) print_repair_health_usage ;;
    health-reset) print_health_reset_usage ;;
    repair-infra) print_repair_infra_usage ;;
    diagnose) print_diagnose_usage ;;
    timers-stop) print_timers_stop_usage ;;
    timers-start) print_timers_start_usage ;;
    maintenance) print_maintenance_usage ;;
    backup) print_backup_usage ;;
    backup-storage) print_backup_storage_usage ;;
    restore) print_restore_usage ;;
    uninstall) print_uninstall_usage ;;
    ""|-h|--help|help) print_global_usage ;;
    *)
      echo "Unknown command: $1" >&2
      print_global_usage >&2
      return 2
      ;;
  esac
}

CMD="${1:-}"
if [ "$CMD" = "help" ]; then
  shift || true
  print_command_usage "${1:-}"
  exit $?
fi

if [ $# -gt 0 ]; then
  shift
fi

case "$CMD" in
  ""|-h|--help)
    print_global_usage
    exit 0
    ;;
  up)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_up_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    source "$INFRA_ROOT/lib/runtime-compose.sh"
    autoteka_runtime_compose up -d --remove-orphans
    exit $?
    ;;
  down)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_down_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    source "$INFRA_ROOT/lib/runtime-compose.sh"
    autoteka_runtime_compose down
    exit $?
    ;;
  watch-changes)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_watch_changes_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/runtime/watch-changes.sh" "$@"
    ;;
  deploy)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_deploy_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/runtime/deploy.sh" "$@"
    ;;
  repair-runtime)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_repair_runtime_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/repair/repair-runtime.sh" "$@"
    ;;
  repair-health)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_repair_health_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/repair/repair-health.sh" "$@"
    ;;
  health-reset)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_health_reset_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/repair/health-reset.sh" "$@"
    ;;
  repair-infra)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_repair_infra_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/repair/repair-infra.sh" "$@"
    ;;
  diagnose)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_diagnose_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/repair/diagnose.sh" "$@"
    ;;
  timers-stop)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_timers_stop_usage
      exit 0
    fi
    ensure_infra_root
    systemctl stop watch-changes.timer 2>/dev/null || true
    systemctl stop server-watchdog.timer 2>/dev/null || true
    systemctl stop server-maintenance.timer 2>/dev/null || true
    exit 0
    ;;
  timers-start)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_timers_start_usage
      exit 0
    fi
    ensure_infra_root
    systemctl enable --now watch-changes.timer 2>/dev/null || true
    systemctl enable --now server-watchdog.timer 2>/dev/null || true
    systemctl enable --now server-maintenance.timer 2>/dev/null || true
    systemctl restart watch-changes.timer server-watchdog.timer server-maintenance.timer 2>/dev/null || true
    exit 0
    ;;
  watchdog)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_watchdog_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/observability/infrastructure/server-watchdog.sh" "$@"
    ;;
  maintenance)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_maintenance_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/maintenance/server-maintenance.sh" "$@"
    ;;
  uninstall)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_uninstall_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/bootstrap/uninstall.sh" "$@"
    ;;
  backup)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_backup_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/maintenance/backup.sh" "$@"
    ;;
  backup-storage)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_backup_storage_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec bash "$INFRA_ROOT/maintenance/storage-backup.sh" "$@"
    ;;
  restore)
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
      print_restore_usage
      exit 0
    fi
    ensure_autoteka_root
    ensure_infra_root
    validate_required_paths
    exec "$INFRA_ROOT/maintenance/restore.sh" "$@"
    ;;
  *)
    echo "Unknown command: $CMD" >&2
    print_global_usage >&2
    exit 2
    ;;
esac
