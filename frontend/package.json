{
  "name": "autoteka-mock-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ci": "npm run test:unit:ci",
    "test:api": "npm run test:api:online",
    "test:api:online": "vitest run tests/TC-API-INTEGRATION.spec.ts",
    "test:unit": "vitest run",
    "test:unit:parallel": "vitest run --pool=forks --maxWorkers=50%",
    "test:unit:ci": "vitest run --pool=forks --maxWorkers=50%",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "test:e2e:headed": "playwright test --config playwright.e2e.config.ts --headed",
    "test:ui:mock": "playwright test --config playwright.ui-mock.config.ts",
    "test:ui:mock:headed": "playwright test --config playwright.ui-mock.config.ts --headed"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "htmlhint": "^1.9.1",
    "markdownlint-cli": "^0.47.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "svgo": "^4.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.8",
    "vitest": "^3.2.4"
  },
  "description": "Это скелет проекта под согласованное ТЗ: каталог плиток, меню (город/категории/фишка), сортировка по алгоритму a/b/c/d, 6 тем (3 стиля × 2 палитры), страница магазина, переход на сайт через кнопку и через \"доскролл вниз\".",
  "main": "postcss.config.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
