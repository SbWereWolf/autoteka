#!/usr/bin/env bash
set -euo pipefail

ENV_FILE="/etc/autoteka/deploy.env"

if [ -f "$ENV_FILE" ]; then
  # shellcheck disable=SC1090
  set -a
  source "$ENV_FILE" || true
  set +a
fi

if [ -z "${AUTOTEKA_ROOT:-}" ]; then
  echo "AUTOTEKA_ROOT is not set. Set it in $ENV_FILE or export AUTOTEKA_ROOT." >&2
  exit 1
fi

CMD="${1:-}"
shift || true

case "$CMD" in
  up)
    exec /usr/bin/docker compose -f "$AUTOTEKA_ROOT/deploy/docker-compose.yml" up -d --remove-orphans
    ;;
  down)
    exec /usr/bin/docker compose -f "$AUTOTEKA_ROOT/deploy/docker-compose.yml" down
    ;;
  watch-changes)
    exec "$AUTOTEKA_ROOT/deploy/watch-changes.sh" "$@"
    ;;
  deploy)
    exec "$AUTOTEKA_ROOT/deploy/deploy.sh" "$@"
    ;;
  repair-runtime)
    exec "$AUTOTEKA_ROOT/deploy/repair-runtime.sh" "$@"
    ;;
  repair-infra)
    exec "$AUTOTEKA_ROOT/deploy/repair-infra.sh" "$@"
    ;;
  watchdog)
    exec "$AUTOTEKA_ROOT/deploy/server-watchdog.sh" "$@"
    ;;
  maintenance)
    exec "$AUTOTEKA_ROOT/deploy/server-maintenance.sh" "$@"
  ;;
  uninstall)
    exec "$AUTOTEKA_ROOT/deploy/uninstall.sh" "$@"
    ;;
  backup)
    exec "$AUTOTEKA_ROOT/deploy/backup.sh" "$@"
    ;;
  restore)
    exec "$AUTOTEKA_ROOT/deploy/restore.sh" "$@"
    ;;
  *)
    cat >&2 <<'USAGE'
Usage:
  autoteka up
  autoteka down
  autoteka watch-changes
  autoteka deploy
  autoteka repair-runtime
  autoteka repair-infra
  autoteka watchdog
  autoteka maintenance
  autoteka backup [--output-dir=/path]
  autoteka restore <archive> [--dry-run] [--force] [--target-root=/path]
  autoteka uninstall [soft|purge|nuke] [--force]
USAGE
    exit 2
    ;;
esac
