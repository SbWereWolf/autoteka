map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

server {
    listen 80;
    server_name _;

    location = /healthcheck {
        access_log off;
        return 204;
    }

    location ^~ /vendor/moonshine/ {
        alias /workspace/backend/public/vendor/moonshine/;
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    location ^~ /storage/ {
        alias /workspace/backend/storage/app/public/;
        expires -1;
        add_header Cache-Control "no-cache";
        try_files $uri =404;
    }

    location ~ ^/api(/|$) {
        if ($request_method = OPTIONS) {
            add_header Access-Control-Allow-Origin "${CORS_ALLOW_ORIGIN}" always;
            add_header Access-Control-Allow-Methods "${CORS_ALLOW_METHODS}" always;
            add_header Access-Control-Allow-Headers "${CORS_ALLOW_HEADERS}" always;
            add_header Access-Control-Expose-Headers "${CORS_EXPOSE_HEADERS}" always;
            add_header Access-Control-Allow-Credentials "${CORS_ALLOW_CREDENTIALS}" always;
            add_header Access-Control-Max-Age "${CORS_MAX_AGE}" always;
            add_header Cache-Control "${API_CACHE_CONTROL_MUTATION}" always;
            add_header Pragma "no-cache" always;
            add_header Expires "0" always;
            add_header Content-Length 0;
            add_header Content-Type text/plain;
            return 204;
        }

        add_header Access-Control-Allow-Origin "${CORS_ALLOW_ORIGIN}" always;
        add_header Access-Control-Allow-Methods "${CORS_ALLOW_METHODS}" always;
        add_header Access-Control-Allow-Headers "${CORS_ALLOW_HEADERS}" always;
        add_header Access-Control-Expose-Headers "${CORS_EXPOSE_HEADERS}" always;
        add_header Access-Control-Allow-Credentials "${CORS_ALLOW_CREDENTIALS}" always;
        set $api_cache_control "${API_CACHE_CONTROL_GET}";
        if ($request_method !~ ^(GET|HEAD)$) {
            set $api_cache_control "${API_CACHE_CONTROL_MUTATION}";
        }
        add_header Cache-Control $api_cache_control always;

        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /workspace/backend/public/index.php;
        fastcgi_param DOCUMENT_ROOT /workspace/backend/public;
        fastcgi_param SCRIPT_NAME /index.php;
        fastcgi_pass php:9000;
    }

    location = /up {
        add_header Cache-Control "${API_CACHE_CONTROL_MUTATION}" always;
        add_header Pragma "no-cache" always;
        add_header Expires "0" always;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /workspace/backend/public/index.php;
        fastcgi_param DOCUMENT_ROOT /workspace/backend/public;
        fastcgi_param SCRIPT_NAME /index.php;
        fastcgi_pass php:9000;
    }

    location ~ ^/admin(/|$) {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /workspace/backend/public/index.php;
        fastcgi_param DOCUMENT_ROOT /workspace/backend/public;
        fastcgi_param SCRIPT_NAME /index.php;
        fastcgi_pass php:9000;
    }

    location / {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600;
        proxy_pass http://frontend:${FRONTEND_PORT};
    }
}
